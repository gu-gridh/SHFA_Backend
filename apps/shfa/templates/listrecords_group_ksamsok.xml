{% extends "base.xml" %}
{% load oai_pmh %}
{% load tz %}
{% block content %}

<ListRecords>
    {% for group in groups %}
        <record>
            <header>
                <identifier>oai:shfa.dh.gu.se:group/{{ group.id }}</identifier>
                <datestamp>{% now "Y-m-d\TH:i:s\Z" %}</datestamp>
                <spec>shfa:models</spec>
            </header>
            <metadata>
                <rdf:RDF xmlns="http://kulturarvsdata.se/ksamsok#"
                        xmlns:foaf="http://xmlns.com/foaf/0.1/#"
                        xmlns:geoF="http://www.mindswap.org/2003/owl/geo/geoFeatures20040307.owl#"
                        xmlns:owl="http://www.w3.org/2002/07/owl#" 
                        xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
                        xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#" 
                        xmlns:time="http://www.w3.org/2006/time#"
                        xmlns:dc="http://purl.org/dc/elements/1.1/"
                        xmlns:dcterms="http://purl.org/dc/terms/">
                <Entity rdf:about="http://kulturarvsdata.se/shfa/group/{{ group.id }}">
                    <ksamsokVersion>1.3.0</ksamsokVersion>
                    <buildDate>{% now "Y-m-d" %}</buildDate>
                    <serviceOrganization>shfa</serviceOrganization>
                    <serviceName>shfa3d</serviceName>
                    <url>https://shfa.dh.gu.se/group/{{ group.id }}</url>
                    <dataQuality rdf:resource="http://kulturarvsdata.se/resurser/DataQuality#raw" />
                    <itemSuperType rdf:resource="http://kulturarvsdata.se/resurser/EntitySuperType#object"/>
                    <itemTitle>{{ group.text }}</itemTitle>
                    <itemLicense rdf:resource="http://kulturarvsdata.se/resurser/License#CC0"/>
                    <itemLicenseUrl rdf:resource="http://creativecommons.org/publicdomain/zero/1.0/"/>
                    <itemLabel>{{ group.text }}</itemLabel>

                    {# ===== Context from first 3D model's site ===== #}
                    {% with first_3d=group.shfa3d_set.all.0 %}
                    {% if first_3d and first_3d.site %}
                    <context rdf:nodeID="ctx001" />
                    {% if first_3d.site.ksamsok_id %}
                    <visualizes>http://kulturarvsdata.se/raa/lamning/{{ first_3d.site.ksamsok_id }}</visualizes>
                    {% endif %}
                    {% endif %}
                    {% endwith %}

                    {# ===== 3D mesh references ===== #}
                    {% for model_3d in group.shfa3d_set.all %}
                    {% if model_3d.three_d_mesh and model_3d.three_d_mesh.mesh_url %}
                    <mesh rdf:nodeID="mesh_{{ model_3d.id }}" />
                    {% endif %}
                    {% endfor %}

                    {# ===== Image references ===== #}
                    {% for image in group.images_set.all %}
                    <image rdf:nodeID="im_{{ image.id }}" />
                    {% endfor %}

                    <presentation rdf:parseType="Literal" xmlns:pres="http://kulturarvsdata.se/presentation#">
                    <pres:item>
                        <pres:version>1.3.0</pres:version>
                        <pres:entityUri>http://kulturarvsdata.se/shfa/group/{{ group.id }}</pres:entityUri>
                        <pres:type>group</pres:type>
                        <pres:id>{{ group.id }}</pres:id>
                        <pres:itemLabel>{{ group.text }}</pres:itemLabel>
                        <pres:description>Visualisation group &quot;{{ group.text }}&quot; with {{ group.shfa3d_set.count }} 3D model(s) and {{ group.images_set.count }} image(s).</pres:description>
                        {% with first_3d=group.shfa3d_set.all.0 %}
                        {% if first_3d and first_3d.site %}
                        <pres:context>
                        <pres:event>-</pres:event>
                        <pres:placeLabel>Län:{{ first_3d.site.province }}, Kommun:{{ first_3d.site.municipality }}, Socken:{{ first_3d.site.parish }}</pres:placeLabel>
                        <pres:timeLabel>-</pres:timeLabel>
                        <pres:nameLabel>-</pres:nameLabel>
                        </pres:context>
                        <georss:where xmlns:georss="http://www.georss.org/georss">
                            {% if first_3d.site.coordinates %}
                                <gml:Point xmlns:gml="http://www.opengis.net/gml" srsName="SDO:4326">
                                    <gml:coordinates cs="," decimal="." ts=" ">
                                        {% for s in first_3d.site.coordinates %}{% if not forloop.first %},{% endif %}{{ s }}{% endfor %}
                                    </gml:coordinates> 
                                </gml:Point>
                            {% endif %}
                        </georss:where>
                        {% endif %}
                        {% endwith %}
                        {# ===== 3D model presentations ===== #}
                        {% for model_3d in group.shfa3d_set.all %}
                        {% if model_3d.three_d_mesh and model_3d.three_d_mesh.mesh_url %}
                        <pres:model3d>
                        <pres:src type="mesh">{{ model_3d.three_d_mesh.mesh_url }}</pres:src>
                        {% if model_3d.three_d_mesh.quality_url %}
                        <pres:src type="quality">{{ model_3d.three_d_mesh.quality_url }}</pres:src>
                        {% endif %}
                        <pres:viewerURL>https://shfa.dh.gu.se/viewer/?q={{ group.text|urlencode }}/mesh</pres:viewerURL>
                        <pres:copyright>SHFA</pres:copyright>
                        <pres:mediaLicense>http://kulturarvsdata.se/resurser/license#by</pres:mediaLicense>
                        </pres:model3d>
                        {% endif %}
                        {% endfor %}
                        {# ===== Image presentations ===== #}
                        {% for image in group.images_set.all %}
                        <pres:image>
                        <pres:src type="thumbnail">https://data.dh.gu.se/shfa/static/{{ image.file }}</pres:src>
                        <pres:src type="lowres">https://data.dh.gu.se/shfa/static/{{ image.file }}</pres:src>
                        <pres:src type="highres">https://img.dh.gu.se/shfa/static/{{ image.iiif_file }}/full/full/0/default.jpg</pres:src>
                        <pres:byline>{{ image.author.name }}</pres:byline>
                        <pres:copyright>SHFA</pres:copyright>
                        <pres:mediaLicense>http://kulturarvsdata.se/resurser/license#by</pres:mediaLicense>
                        </pres:image>
                        {% endfor %}
                        <pres:representations>
                        <pres:representation format="HTML">http://kulturarvsdata.se/shfa/group/html/{{ group.id }}</pres:representation>
                        <pres:representation format="RDF">http://kulturarvsdata.se/shfa/group/rdf/{{ group.id }}</pres:representation>
                        </pres:representations>
                        <pres:organization>Svenskt HällristningsForskningsarkiv</pres:organization>
                        <pres:organizationShort>SHFA</pres:organizationShort>
                        <pres:service>3d</pres:service>
                        <pres:dataQuality>Rådata</pres:dataQuality>
                        <pres:buildDate>{% now "Y-m-d" %}</pres:buildDate>
                    </pres:item>
                    </presentation>
                </Entity>
                {# ===== Context from first 3D model's site ===== #}
                {% with first_3d=group.shfa3d_set.all.0 %}
                {% if first_3d and first_3d.site %}
                <Context rdf:nodeID="ctx001">
                        <contextType rdf:resource="http://kulturarvsdata.se/resurser/ContextType#produce"/>
                        <contextSuperType rdf:resource="http://kulturarvsdata.se/resurser/ContextSuperType#create"/>
                        <contextLabel>Plats</contextLabel> 
                        <continentName>Europa</continentName> 
                        <country rdf:resource="http://kulturarvsdata.se/resurser/aukt/geo/country#se"/> 
                        <countryName>Sverige</countryName>
                        <countyName>{{ first_3d.site.province }}</countyName>
                        <provinceName>{{ first_3d.site.province }}</provinceName> 
                        <municipalityName>{{ first_3d.site.municipality }}</municipalityName> 
                        <parishName>{{ first_3d.site.parish }}</parishName> 
                        <coordinates rdf:parseType="Literal">
                            {% if first_3d.site.coordinates %}
                            <gml:Point xmlns:gml="http://www.opengis.net/gml" srsName="SDO:4326">
                                <gml:coordinates cs="," decimal="." ts=" ">
                                    {% for s in first_3d.site.coordinates %}{% if not forloop.first %},{% endif %}{{ s }}{% endfor %}
                                </gml:coordinates> 
                            </gml:Point>
                            {% endif %}
                        </coordinates>
                </Context>
                {% endif %}
                {% endwith %}
                {# ===== 3D Mesh nodes ===== #}
                {% for model_3d in group.shfa3d_set.all %}
                {% if model_3d.three_d_mesh and model_3d.three_d_mesh.mesh_url %}
                <Mesh rdf:nodeID="mesh_{{ model_3d.id }}">
                    <mediaType>model/gltf+json</mediaType>
                    <meshSource>{{ model_3d.three_d_mesh.mesh_url }}</meshSource>
                    {% if model_3d.three_d_mesh.quality_url %}
                    <qualitySource>{{ model_3d.three_d_mesh.quality_url }}</qualitySource>
                    {% endif %}
                    {% if model_3d.three_d_mesh.method %}
                    <method>{{ model_3d.three_d_mesh.method.text }}</method>
                    {% endif %}
                    <numVertices>{{ model_3d.three_d_mesh.num_vertices }}</numVertices>
                    <numFaces>{{ model_3d.three_d_mesh.num_faces }}</numFaces>
                    {% if model_3d.three_d_mesh.num_photos %}
                    <numPhotos>{{ model_3d.three_d_mesh.num_photos }}</numPhotos>
                    {% endif %}
                    <mediaMotiveWord>{% get_3d_tags model_3d %}</mediaMotiveWord>
                    <viewerURL>https://shfa.dh.gu.se/viewer/?q={{ group.text|urlencode }}/mesh</viewerURL>
                    <copyright>SHFA</copyright>
                    <mediaLicense rdf:resource="http://kulturarvsdata.se/resurser/license#by"/>
                    <mediaLicenseUrl rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
                </Mesh>
                {% endif %}
                {% endfor %}
                {# ===== Image nodes ===== #}
                {% for image in group.images_set.all %}
                <Image rdf:nodeID="im_{{ image.id }}">
                    <mediaType>image/jpeg</mediaType>
                    <thumbnailSource>https://data.dh.gu.se/shfa/static/{{ image.file }}</thumbnailSource>
                    <lowresSource>https://data.dh.gu.se/shfa/static/{{ image.file }}</lowresSource>
                    <highresSource>https://img.dh.gu.se/shfa/static/{{ image.iiif_file }}/full/full/0/default.jpg</highresSource>
                    <byline>{{ image.author.name }}</byline>
                    <mediaMotiveWord>{% get_image_tags image %}</mediaMotiveWord>
                    <copyright>SHFA</copyright>
                    <mediaLicense rdf:resource="http://kulturarvsdata.se/resurser/license#by"/>
                    <mediaLicenseUrl rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
                </Image>
                {% endfor %}
                </rdf:RDF>
            </metadata>
        </record>
    {% endfor %}

    {% resumption_token paginator groups metadata_prefix from_timestamp until_timestamp %}
</ListRecords>
{% endblock %}
