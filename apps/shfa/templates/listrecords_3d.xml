{% extends "base.xml" %}
{% load oai_pmh %}
{% load tz %}
{% block content %}

<ListRecords>
    {% for model_3d in models_3d %}
        {% if model_3d.site.coordinates %}
            <record>
                <header>
                    <identifier>oai:shfa.dh.gu.se:3d/{{model_3d.id}}</identifier>
                    <datestamp>{% now "Y-m-d\TH:i:s\Z" %}</datestamp>
                    <setSpec>shfa:3d</setSpec>
                </header>
                <metadata>
                    <rdf:RDF xmlns="http://kulturarvsdata.se/ksamsok#"
                            xmlns:foaf="http://xmlns.com/foaf/0.1/#"
                            xmlns:geoF="http://www.mindswap.org/2003/owl/geo/geoFeatures20040307.owl#"
                            xmlns:owl="http://www.w3.org/2002/07/owl#" 
                            xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
                            xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#" 
                            xmlns:time="http://www.w3.org/2006/time#"
                            xmlns:dc="http://purl.org/dc/elements/1.1/"
                            xmlns:dcterms="http://purl.org/dc/terms/">
                    <Entity rdf:about="http://kulturarvsdata.se/{{"shfa"}}/{{"3d"}}/{{model_3d.id}}">
                        <ksamsokVersion>1.3.0</ksamsokVersion>
                        <buildDate>{% now "Y-m-d" %}</buildDate>
                        <createdDate>{{model_3d.created_at|date:"Y-m-d"}}</createdDate>
                        <lastChangedDate>{{model_3d.updated_at|date:"Y-m-d"}}</lastChangedDate>
                        <serviceOrganization>{{"shfa"}}</serviceOrganization>
                        <serviceName>{{"shfa3d"}}</serviceName>
                        <url>https://shfa.dh.gu.se/3d/{{model_3d.id}}</url>
                        {% if model_3d.three_d_mesh and model_3d.three_d_mesh.mesh_url %}
                        <mediaType>{{"model/gltf+json"}}</mediaType>
                        {% endif %}
                        <dataQuality rdf:resource="{{"http://kulturarvsdata.se/resurser/DataQuality#raw"}}" />
                        <itemType rdf:resource="{{"http://kulturarvsdata.se/resurser/EntityType#3dmodel"}}" />
                        <itemSuperType rdf:resource="http://kulturarvsdata.se/resurser/EntitySuperType#object"/>
                        <itemTitle>{{model_3d.site.raa_id}}</itemTitle>
                        <itemLicense rdf:resource="http://kulturarvsdata.se/resurser/License#CC0"/>
                        <itemLicenseUrl rdf:resource="http://creativecommons.org/publicdomain/zero/1.0/"/>
                        <itemName rdf:nodeID="name001" />
                        <itemLabel>{% get_3d_title model_3d %}</itemLabel>
                        <itemMotiveWord>{% get_3d_tags model_3d %}</itemMotiveWord>
                        {% if model_3d.three_d_mesh and model_3d.three_d_mesh.method %}
                        <itemTechnique>{{model_3d.three_d_mesh.method.text}}</itemTechnique>
                        {% endif %}
                        <ItemNumber rdf:nodeID="num001"/>
                        <ItemNumber rdf:nodeID="num002"/>
                        <context rdf:nodeID="ctx001" />
                        <visualizes>http://kulturarvsdata.se/raa/lamning/{{model_3d.site.ksamsok_id}}</visualizes>
                        {% if model_3d.three_d_mesh and model_3d.three_d_mesh.mesh_url %}
                        <mesh rdf:nodeID="mesh001" />
                        {% endif %}
                        <presentation rdf:parseType="Literal" xmlns:pres="http://kulturarvsdata.se/presentation#">
                        <pres:item>
                            <pres:version>1.3.0</pres:version>
                            <pres:entityUri>http://kulturarvsdata.se/shfa/3d/{{model_3d.id}}</pres:entityUri>
                            {% if model_3d.three_d_mesh and model_3d.three_d_mesh.method %}
                            <pres:type>{{model_3d.three_d_mesh.method.text}}</pres:type>
                            {% endif %}
                            <pres:id>{{model_3d.id}}</pres:id>
                            <pres:idLabel>{{model_3d.site.lamning_id}}</pres:idLabel>
                            <pres:itemLabel>{% get_3d_title model_3d %}</pres:itemLabel>
                            <pres:description>{% get_3d_creators model_3d %}, Institution: {{model_3d.institution.name}}{% if model_3d.date %}, Date: {{model_3d.date|date:"Y-m-d"}}{% endif %}</pres:description>
                            <pres:context>
                            <pres:event>-</pres:event>
                            <pres:placeLabel>Län:{{model_3d.site.province}}, Kommun:{{model_3d.site.municipality}}, Socken:{{model_3d.site.parish}}</pres:placeLabel>
                            <pres:timeLabel>-</pres:timeLabel>
                            <pres:nameLabel>-</pres:nameLabel>
                            </pres:context>
                            <georss:where xmlns:georss="http://www.georss.org/georss">
                                {% if model_3d.site.coordinates %}
                                    <gml:Point xmlns:gml="http://www.opengis.net/gml" srsName="SDO:4326">
                                        <gml:coordinates cs="," decimal="." ts=" ">
                                            {% for s in model_3d.site.coordinates %}{% if not forloop.first %},{% endif %}{{s}}{% endfor %}
                                        </gml:coordinates> 
                                    </gml:Point>
                                {% endif %}
                            </georss:where>
                            {% if model_3d.three_d_mesh and model_3d.three_d_mesh.mesh_url %}
                            <pres:3dModel>
                            <pres:src type="mesh">{{model_3d.three_d_mesh.mesh_url}}</pres:src>
                            {% if model_3d.three_d_mesh.quality_url %}
                            <pres:src type="quality">{{model_3d.three_d_mesh.quality_url}}</pres:src>
                            {% endif %}
                            <pres:copyright>{{"SHFA"}}</pres:copyright>
                            <pres:mediaLicense>http://kulturarvsdata.se/resurser/license#by</pres:mediaLicense>
                            </pres:3dModel>
                            {% endif %}
                            <pres:representations>
                            <pres:representation format="HTML">http://kulturarvsdata.se/shfa/3d/html/{{model_3d.id}}</pres:representation>
                            <pres:representation format="XML">http://kulturarvsdata.se/shfa/3d/xml/{{model_3d.id}}</pres:representation>
                            <pres:representation format="RDF">http://kulturarvsdata.se/shfa/3d/rdf/{{model_3d.id}}</pres:representation>
                            </pres:representations>
                            <pres:organization>Svenskt HällristningsForskningsarkiv</pres:organization>
                            <pres:organizationShort>SHFA</pres:organizationShort>
                            <pres:service>3d</pres:service>
                            <pres:dataQuality>Rådata</pres:dataQuality>
                            <pres:buildDate>{% now "Y-m-d" %}</pres:buildDate>
                        </pres:item>
                        </presentation>
                    </Entity>
                    <Context rdf:nodeID="ctx001">
                            <contextType rdf:resource="http://kulturarvsdata.se/resurser/ContextType#produce"/>
                            <contextSuperType rdf:resource="http://kulturarvsdata.se/resurser/ContextSuperType#create"/>
                            <contextLabel>Plats</contextLabel> 
                            <continentName>Europa</continentName> 
                            <country rdf:resource="http://kulturarvsdata.se/resurser/aukt/geo/country#se"/> 
                            <countryName>Sverige</countryName>
                            <countyName>{{model_3d.site.province}}</countyName>
                            <provinceName>{{model_3d.site.province}}</provinceName> 
                            <municipalityName>{{model_3d.site.municipality}}</municipalityName> 
                            <parishName>{{model_3d.site.parish}}</parishName> 
                            <coordinates rdf:parseType="Literal">
                                {% if model_3d.site.coordinates %}
                                <gml:Point xmlns:gml="http://www.opengis.net/gml" srsName="SDO:4326">
                                    <gml:coordinates cs="," decimal="." ts=" ">
                                        {% for s in model_3d.site.coordinates %}{% if not forloop.first %},{% endif %}{{s}}{% endfor %}
                                    </gml:coordinates> 
                                </gml:Point>
                                {% endif %}
                            </coordinates>
                    </Context>
                    {% if model_3d.three_d_mesh and model_3d.three_d_mesh.mesh_url %}
                    <Mesh rdf:nodeID="mesh001">
                        <mediaType>model/gltf+json</mediaType>
                        <meshSource>{{model_3d.three_d_mesh.mesh_url}}</meshSource>
                        {% if model_3d.three_d_mesh.quality_url %}
                        <qualitySource>{{model_3d.three_d_mesh.quality_url}}</qualitySource>
                        {% endif %}
                        {% if model_3d.three_d_mesh.method %}
                        <method>{{model_3d.three_d_mesh.method.text}}</method>
                        {% endif %}
                        <numVertices>{{model_3d.three_d_mesh.num_vertices}}</numVertices>
                        <numFaces>{{model_3d.three_d_mesh.num_faces}}</numFaces>
                        {% if model_3d.three_d_mesh.num_photos %}
                        <numPhotos>{{model_3d.three_d_mesh.num_photos}}</numPhotos>
                        {% endif %}
                        <copyright>SHFA</copyright>
                        <mediaLicense rdf:resource="http://kulturarvsdata.se/resurser/license#by"/>
                        <mediaLicenseUrl rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
                    </Mesh>
                    {% endif %}
                    <ItemNumber rdf:nodeID="num001">
                        <type>RAÄ-nummer</type>
                        <number>{{model_3d.site.raa_id}}</number>
                    </ItemNumber>
                    <ItemNumber rdf:nodeID="num002">
                        <type>Lämningsnummer</type>
                        <number>{{model_3d.site.lamning_id}}</number>
                    </ItemNumber>
                    <ItemName rdf:nodeID="name001">
                        <type>{% get_3d_tags model_3d %}</type>
                        <name>hällristning</name>
                    </ItemName>
                    </rdf:RDF>
                </metadata>
            </record>
        {% endif %}
    {% endfor %}
    {% resumption_token paginator models_3d metadata_prefix from_timestamp until_timestamp %}
</ListRecords>
{% endblock %}
