{% extends "base.xml" %}
{% load oai_pmh %}
{% load tz %}
{% block content %}

<ListSets>
    {% for set in sets %}
        <set>
            <spec>{{ set.spec }}</spec>
            <setName>{{ set.name }}</setName>
            {% if set.description %}
                <setDescription>{% autoescape off %}{{ set.description }}{% endautoescape %}</setDescription>
            {% endif %}
        </set>
    {% endfor %}
    {% resumption_token paginator sets %}
</ListSets>

{% endblock %}
