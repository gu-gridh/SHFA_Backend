{% extends "base.xml" %}
{% load oai_pmh %}
{% load tz %}
{% block content %}

<ListRecords>
    {% for site in sites %}
        <record>
            <header>
                <identifier>oai:shfa.dh.gu.se:site/{{ site.id }}</identifier>
                <datestamp>{% now "Y-m-d\\TH:i:s\\Z" %}</datestamp>
            </header>

            <metadata>
                <rdf:RDF
                    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
                    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
                    xmlns:rdf4j="http://rdf4j.org/schema/rdf4j#"
                    xmlns:sesame="http://www.openrdf.org/schema/sesame#"
                    xmlns:owl="http://www.w3.org/2002/07/owl#"
                    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
                    xmlns:fn="http://www.w3.org/2005/xpath-functions#">

                    <Entity rdf:about="https://shfa.dh.gu.se/site/{{ site.id }}">
                        <rdf:type rdf:resource="https://www.ariadne-infrastructure.eu/resource/ao/cat/1.1/AO_Entity"/>
                        <rdfs:label>Record SHFA Site {{ site.id }}</rdfs:label>
                        <has_publisher xmlns="https://www.ariadne-infrastructure.eu/resource/ao/cat/1.1/" rdf:resource="https://ariadne-infrastructure.eu/aocat/Agent/Swedish%20Rock%20Art%20Research%20Archives"/>
                        <has_title>{{ site.placename }}</has_title>
                        <affiliation>SHFA</affiliation>
                        <description_en xml:lang="en">Rock art site {{ site.placename }} with {{ site.image_set.count }} image(s) and {{ site.shfa3d_set.count }} 3D model(s).</description_en>
                        <description_sv xml:lang="sv">Hällristningslokal {{ site.placename }} med {{ site.image_set.count }} bild(er) och {{ site.shfa3d_set.count }} 3D-modell(er).</description_sv>
                        <has_access_rights xmlns="https://www.ariadne-infrastructure.eu/resource/ao/cat/1.1/" rdf:resource="https://creativecommons.org/licenses/by/4.0/" />
                        <has_responsible xmlns="https://www.ariadne-infrastructure.eu/resource/ao/cat/1.1/" rdf:resource="https://ariadne-infrastructure.eu/aocat/Agent/SHFA"/>

                        {# ===== Site identifiers ===== #}
                        <site_id>{{ site.id }}</site_id>
                        {% if site.raa_id %}
                            <RAÄ_nr>{{ site.raa_id }}</RAÄ_nr>
                        {% endif %}
                        {% if site.lamning_id %}
                            <lamningsnummer>{{ site.lamning_id }}</lamningsnummer>
                        {% endif %}
                        {% if site.askeladden_id %}
                            <askeladden_id>{{ site.askeladden_id }}</askeladden_id>
                        {% endif %}
                        {% if site.lokalitet_id %}
                            <lokalitet_id>{{ site.lokalitet_id }}</lokalitet_id>
                        {% endif %}
                        <site_name>{{ site.placename }}</site_name>

                        {# ===== Location ===== #}
                        <country>{{ site.municipality.superregion.superregion.superregion.superregion.name }}</country>
                        <municipality>{{ site.municipality.superregion.name }}</municipality>
                        <province>{{ site.province.name }}</province>
                        <parish>{{ site.parish.name }}</parish>
                        <county>{{ site.province.name }}</county>
                        <latitude>{{ site.coordinates.y }}</latitude>
                        <longitude>{{ site.coordinates.x }}</longitude>
                        <URL>https://shfa.dh.gu.se/site/{{ site.id }}</URL>
                        <copyright>CC-BY</copyright>

                        {# ===== Unique keywords across all items at this site ===== #}
                        {% get_site_unique_keywords site as site_keywords %}
                        {% for tag in site_keywords %}
                            <keywords>
                                <sourceLabel>{{ tag.text }}</sourceLabel>
                                <sourceLabelLanguage>sv</sourceLabelLanguage>
                                {% if tag.att_vocab %}
                                <matchURI>{{ tag.att_vocab.skos_match }}</matchURI>
                                <targetLabel>{{ tag.att_vocab.terms }}</targetLabel>
                                <targetURI>{{ tag.att_vocab.link }}</targetURI>
                                {% endif %}
                            </keywords>
                        {% endfor %}

                        {# ===== Images ===== #}
                        {% for image in site.image_set.all %}
                        <image>
                            <image_id>{{ image.id }}</image_id>
                            <shfa_archive_id>{{ image.legacy_id }}</shfa_archive_id>
                            <has_title>{% get_image_title image %}</has_title>
                            <description_en xml:lang="en">{{ image.type.english_translation }} of {{ image.rock_carving_object.name }}, {{ site.placename }}, created by {% get_image_creators image %} at {{ image.institution.name }} ({{ image.year }}).</description_en>
                            <description_sv xml:lang="sv">{{ image.type.text }} av {{ image.rock_carving_object.name }}, {{ site.placename }}, skapad av {% get_image_creators image %} på {{ image.institution.name }} ({{ image.year }}).</description_sv>
                            <was_modified xmlns="https://www.ariadne-infrastructure.eu/resource/ao/cat/1.1/" rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">{{ image.updated_at|date:"Y-m-d" }}</was_modified>
                            <was_issued xmlns="https://www.ariadne-infrastructure.eu/resource/ao/cat/1.1/" rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">{{ image.created_at|date:"Y-m-d" }}</was_issued>
                            <imageURL>{{ image.file }}</imageURL>
                            <URL>https://shfa.dh.gu.se/image/{{ image.id }}</URL>
                            <iiifFile>{{ image.iiif_file }}</iiifFile>
                            <iiifManifest>{{ image.iiif_file }}/info.json</iiifManifest>
                            {% for person in image.people.all %}
                                <originator>{{ person.english_translation }}</originator>
                            {% endfor %}
                            <type>{{ image.type.text }}</type>
                            {% if image.subtype %}
                            <subtype>{{ image.subtype.english_translation }}</subtype>
                            {% endif %}
                            <year>{{ image.year }}</year>
                            {% for period in image.dating_tags.all %}
                                <period>{{ period.text }}</period>
                            {% endfor %}
                        </image>
                        {% endfor %}

                        {# ===== 3D Models ===== #}
                        {% for model_3d in site.shfa3d_set.all %}
                        <model3d>
                            <model_3d_id>{{ model_3d.id }}</model_3d_id>
                            <has_title>{% get_3d_title model_3d %}</has_title>
                            <description_en xml:lang="en">3D model of {{ site.placename }}, created by {% get_3d_creators model_3d %} at {{ model_3d.institution.name }}{% if model_3d.date %} ({{ model_3d.date|date:"Y" }}){% endif %}.</description_en>
                            <description_sv xml:lang="sv">3D-modell av {{ site.placename }}, skapad av {% get_3d_creators model_3d %} på {{ model_3d.institution.name }}{% if model_3d.date %} ({{ model_3d.date|date:"Y" }}){% endif %}.</description_sv>
                            <was_modified xmlns="https://www.ariadne-infrastructure.eu/resource/ao/cat/1.1/" rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">{{ model_3d.updated_at|date:"Y-m-d" }}</was_modified>
                            <was_issued xmlns="https://www.ariadne-infrastructure.eu/resource/ao/cat/1.1/" rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">{{ model_3d.created_at|date:"Y-m-d" }}</was_issued>
                            {% if model_3d.three_d_mesh and model_3d.three_d_mesh.mesh_url %}
                            <meshURL>{{ model_3d.three_d_mesh.mesh_url }}</meshURL>
                            {% endif %}
                            <URL>https://shfa.dh.gu.se/3d/{{ model_3d.id }}</URL>
                            {% for creator in model_3d.creators.all %}
                                <originator>{{ creator.name }}</originator>
                            {% endfor %}
                            {% if model_3d.three_d_mesh and model_3d.three_d_mesh.method %}
                            <method>{{ model_3d.three_d_mesh.method.text }}</method>
                            {% endif %}
                            {% if model_3d.date %}
                            <date>{{ model_3d.date|date:"Y-m-d" }}</date>
                            {% endif %}
                            {% if model_3d.three_d_mesh %}
                            <mesh_details>
                                <num_vertices>{{ model_3d.three_d_mesh.num_vertices }}</num_vertices>
                                <num_faces>{{ model_3d.three_d_mesh.num_faces }}</num_faces>
                                {% if model_3d.three_d_mesh.num_photos %}
                                <num_photos>{{ model_3d.three_d_mesh.num_photos }}</num_photos>
                                {% endif %}
                            </mesh_details>
                            {% endif %}
                            {% for period in model_3d.datings.all %}
                                <period>{{ period.text }}</period>
                            {% endfor %}
                        </model3d>
                        {% endfor %}

                    </Entity>
                </rdf:RDF>
            </metadata>
        </record>
    {% endfor %}

    {% resumption_token paginator sites metadata_prefix from_timestamp until_timestamp %}
</ListRecords> 
{% endblock %}

